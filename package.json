{
  "name": "lms-platform",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "db:migrate": "turbo run db:migrate --filter=@lms/database",
    "db:generate": "turbo run db:generate --filter=@lms/database",
    "start:api": "node apps/api/dist/index.js",
    "start:web": "cd apps/web && npx next start -p ${PORT:-3000}"
  },
  "devDependencies": {
    "prettier": "^3.4.0",
    "shadcn": "^4.1.0",
    "turbo": "^2.4.0",
    "typescript": "^5.9.3"
  },
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "skillfish": "^1.0.30"
  }
}
