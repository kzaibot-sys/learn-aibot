generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String?   @unique
  passwordHash String?   @map("password_hash")
  firstName    String?   @map("first_name")
  lastName     String?   @map("last_name")
  middleName   String?   @map("middle_name")
  phone        String?   @map("phone")
  avatarUrl    String?   @map("avatar_url")
  role         UserRole  @default(STUDENT)
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  telegramAccount TelegramAccount?
  enrollments     Enrollment[]
  payments        Payment[]
  progress        LessonProgress[]
  submissions     TaskSubmission[]
  certificates    Certificate[]
  refreshTokens   RefreshToken[]
  notifications   Notification[]

  @@map("users")
}

enum UserRole {
  STUDENT
  TEACHER
  ADMIN
}

model TelegramAccount {
  id         String   @id @default(cuid())
  userId     String   @unique @map("user_id")
  telegramId String   @unique @map("telegram_id")
  username   String?
  firstName  String?  @map("first_name")
  lastName   String?  @map("last_name")
  linkedAt   DateTime @default(now()) @map("linked_at")

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions TelegramSession[]

  @@map("telegram_accounts")
}

model TelegramSession {
  id          String   @id @default(cuid())
  tgAccountId String   @map("tg_account_id")
  sessionData Json     @map("session_data")
  expiresAt   DateTime @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")

  account TelegramAccount @relation(fields: [tgAccountId], references: [id], onDelete: Cascade)

  @@map("telegram_sessions")
}

model ChatMessage {
  id         String          @id @default(cuid())
  telegramId String          @map("telegram_id")
  role       ChatMessageRole
  content    String
  metadata   Json?
  createdAt  DateTime        @default(now()) @map("created_at")

  @@index([telegramId, createdAt])
  @@map("chat_messages")
}

enum ChatMessageRole {
  USER
  ASSISTANT
  SYSTEM
}

model Course {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String?
  coverUrl    String?  @map("cover_url")
  price       Decimal  @db.Decimal(10, 2)
  currency    String   @default("RUB")
  isPublished Boolean  @default(false) @map("is_published")
  isFree      Boolean  @default(false) @map("is_free")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  modules      Module[]
  enrollments  Enrollment[]
  payments     Payment[]
  certificates Certificate[]

  @@map("courses")
}

model Module {
  id          String   @id @default(cuid())
  courseId    String   @map("course_id")
  title       String
  description String?
  order       Int      @default(0)
  isPublished Boolean  @default(false) @map("is_published")
  createdAt   DateTime @default(now()) @map("created_at")

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@index([courseId, order])
  @@map("modules")
}

model Lesson {
  id          String     @id @default(cuid())
  moduleId    String     @map("module_id")
  title       String
  description String?
  type        LessonType @default(VIDEO)
  videoUrl    String?    @map("video_url")
  videoKey    String?    @map("video_key")
  duration    Int?
  content     String?
  order       Int        @default(0)
  isFree      Boolean    @default(false) @map("is_free")
  isPublished Boolean    @default(false) @map("is_published")
  createdAt   DateTime   @default(now()) @map("created_at")

  module   Module           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress LessonProgress[]
  tasks    Task[]

  @@index([moduleId, order])
  @@map("lessons")
}

enum LessonType {
  VIDEO
  TEXT
  QUIZ
}

model Task {
  id          String   @id @default(cuid())
  lessonId    String   @map("lesson_id")
  title       String
  description String
  type        TaskType @default(TEXT)
  maxScore    Int      @default(100) @map("max_score")
  createdAt   DateTime @default(now()) @map("created_at")

  lesson      Lesson           @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  submissions TaskSubmission[]

  @@map("tasks")
}

enum TaskType {
  TEXT
  FILE
  QUIZ
}

model TaskSubmission {
  id          String           @id @default(cuid())
  taskId      String           @map("task_id")
  userId      String           @map("user_id")
  content     String?
  fileUrl     String?          @map("file_url")
  score       Int?
  status      SubmissionStatus @default(PENDING)
  feedback    String?
  submittedAt DateTime         @default(now()) @map("submitted_at")
  reviewedAt  DateTime?        @map("reviewed_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@map("task_submissions")
}

enum SubmissionStatus {
  PENDING
  REVIEWED
  PASSED
  FAILED
}

model LessonProgress {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  lessonId    String    @map("lesson_id")
  completed   Boolean   @default(false)
  watchedSec  Int       @default(0) @map("watched_sec")
  completedAt DateTime? @map("completed_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@map("lesson_progress")
}

model Enrollment {
  id         String           @id @default(cuid())
  userId     String           @map("user_id")
  courseId   String           @map("course_id")
  status     EnrollmentStatus @default(ACTIVE)
  enrolledAt DateTime         @default(now()) @map("enrolled_at")
  expiresAt  DateTime?        @map("expires_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@map("enrollments")
}

enum EnrollmentStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

model Payment {
  id                String          @id @default(cuid())
  userId            String          @map("user_id")
  courseId          String          @map("course_id")
  amount            Decimal         @db.Decimal(10, 2)
  currency          String          @default("RUB")
  status            PaymentStatus   @default(PENDING)
  provider          PaymentProvider
  providerPaymentId String?         @unique @map("provider_payment_id")
  providerData      Json?           @map("provider_data")
  receiptUrl        String?         @map("receipt_url")
  createdAt         DateTime        @default(now()) @map("created_at")
  confirmedAt       DateTime?       @map("confirmed_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("payments")
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REFUNDED
}

enum PaymentProvider {
  YOOKASSA
  STRIPE
  MANUAL
}

model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  type      String   @default("info")
  title     String
  message   String
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Certificate {
  id       String   @id @default(cuid())
  userId   String   @map("user_id")
  courseId String   @map("course_id")
  number   String   @unique
  fileUrl  String?  @map("file_url")
  issuedAt DateTime @default(now()) @map("issued_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@map("certificates")
}

