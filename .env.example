# Database
DATABASE_URL="postgresql://user:password@localhost:5432/lms_db"
REDIS_URL="redis://localhost:6379"

# Auth
JWT_SECRET="change-in-production"
JWT_EXPIRES_IN="7d"

# Telegram
TELEGRAM_BOT_TOKEN="token-from-BotFather"
TELEGRAM_WEBHOOK_URL="https://yourdomain.com/api/bot/webhook"
TELEGRAM_MINI_APP_URL="https://yourdomain.com/mini-app"

# AI
ANTHROPIC_API_KEY="sk-ant-..."

# YooKassa
YOOKASSA_SHOP_ID="your-shop-id"
YOOKASSA_SECRET_KEY="your-secret-key"

# Stripe
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PUBLISHABLE_KEY="pk_live_..."

# S3 / Cloudflare R2
S3_ENDPOINT="https://..."
S3_ACCESS_KEY="..."
S3_SECRET_KEY="..."
S3_BUCKET_NAME="lms-media"
S3_PUBLIC_URL="https://media.yourdomain.com"

# URLs
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Server port (Railway sets PORT automatically)
PORT=3001
API_PORT=3001

# Payments (set to "true" to enable payment processing)
PAYMENT_ENABLED="false"
